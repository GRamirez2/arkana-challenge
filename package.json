{
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev:db": "docker compose -f docker-compose.dev.yml up",
    "dev:db:init": "DATABASE_URL=postgresql://postgres:postgres@localhost:5432/arkana?schema=public npm run --workspace backend db:push",
    "dev": "concurrently -n backend,frontend -c cyan,magenta \"npm run dev --workspace backend\" \"npm run dev --workspace frontend\"",
    "dev:backend": "npm run dev --workspace backend",
    "dev:frontend": "npm run dev --workspace frontend",
    "seed": "npm run seed --workspace backend",
    "build": "npm run build --workspace backend && npm run build --workspace frontend",
    "build:backend": "npm run build --workspace backend",
    "build:frontend": "npm run build --workspace frontend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "tsx": "^4.23.1"
  }
}
