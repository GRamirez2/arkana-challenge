# Optional OpenAI settings for Docker Compose/backend runtime
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# Other model options (copy/paste one into OPENAI_MODEL):
# OPENAI_MODEL=gpt-4.1      # strongest reasoning, usually slower and higher cost
# OPENAI_MODEL=gpt-4o       # best multimodal generalist, balanced quality/speed
# OPENAI_MODEL=gpt-4o-mini  # lower cost and faster, with lighter reasoning depth
# OPENAI_MODEL=o4-mini      # optimized for tool/logic tasks, often fast and efficient

# Optional backend/browser settings
CORS_ORIGINS=http://localhost:5173,http://localhost:8080
VITE_API_BASE_URL=
